SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///db.sqlite3
CHANNEL_LAYER_BACKEND=channels.layers.InMemoryChannelLayer
MEDIA_ROOT=media

JWT_REFRESH_COOKIE_SECURE=False
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_PATH=/api/users/


# Production-only
# REDIS_URL=redis://localhost:6379/0
# ENABLE_PLAIN_HTTP_HEALTHCHECK=False
# NUM_PROXIES=1

# Email verification
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@tidemate.local
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_MAX_AGE_SECONDS=86400

# Optional geospatial acceleration (PostgreSQL + PostGIS)
POSTGIS_ENABLED=True
LISTING_SEARCH_MAX_LIMIT=48
LISTING_SEARCH_MAX_RADIUS_KM=500
LISTING_SEARCH_FALLBACK_MIN_CANDIDATES=48
LISTING_SEARCH_FALLBACK_MAX_CANDIDATES=250
DEBUG_LINKS_ENABLED=False

# Content Security Policy
# In production, use CSP_REPORT_ONLY=True first to test without breaking pages.
CSP_ENABLED=True
CSP_REPORT_ONLY=False

# Usually empty. Add trusted script hosts only if absolutely needed.
# Do NOT add 'unsafe-inline' here unless you are temporarily debugging breakage.
CSP_SCRIPT_SRC_EXTRA=

# Optional extra allowed sources
CSP_STYLE_SRC_EXTRA=
CSP_CONNECT_SRC_EXTRA=
CSP_IMG_SRC_EXTRA=
CSP_FRAME_SRC_EXTRA=

# Backend geocoding proxy used by the boat location picker
GEOCODING_PROVIDER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_PROVIDER_USER_AGENT="Tidemate/1.0 (contact: your-email@example.com)"
GEOCODING_COUNTRY_CODES=no
GEOCODING_SEARCH_LIMIT=5
GEOCODING_QUERY_MAX_LENGTH=120
GEOCODING_TIMEOUT_SECONDS=4
GEOCODING_SEARCH_CACHE_SECONDS=86400
GEOCODING_REVERSE_CACHE_SECONDS=604800