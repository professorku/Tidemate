# Optional in local development when using the Vite proxy.
# Leave unset to use /api and avoid localhost vs 127.0.0.1 CSRF issues.
# VITE_API_BASE_URL=http://localhost:8000/api

# Optional API timeout in milliseconds. Defaults to 15000 when unset.
# VITE_API_TIMEOUT_MS=15000

# Optional websocket override for deployments where the websocket host differs
# from the current browser host. Leave unset to default to window.location.host.
# VITE_WS_BASE_URL=ws://localhost:8000

# Optional frontend URL for emails is configured in backend/.env.example