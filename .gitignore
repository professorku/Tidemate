# =========================================================
# Tidemate .gitignore
# Django backend + React/Vite frontend
# =========================================================


# =========================================================
# Environment files / secrets
# =========================================================

.env
.env.*
!.env.example
!.env.*.example

backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.*.example

frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env.*.example

*.pem
*.key
*.crt
*.p12
*.pfx


# =========================================================
# Python / Django
# =========================================================

__pycache__/
*.py[cod]
*$py.class

*.so
.Python

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

backend/db.sqlite3
backend/db.sqlite3-journal

backend/media/
backend/staticfiles/
backend/static/
backend/logs/
backend/*.log


# =========================================================
# Python virtual environments
# =========================================================

.venv/
venv/
env/
ENV/

backend/.venv/
backend/venv/
backend/env/

frontend/.venv/
frontend/venv/
frontend/env/


# =========================================================
# Node / React / Vite
# =========================================================

node_modules/
frontend/node_modules/

dist/
frontend/dist/

build/
frontend/build/

.vite/
frontend/.vite/

coverage/
frontend/coverage/

.npm/
.pnpm-store/

npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*


# =========================================================
# Local generated files / temporary files
# =========================================================

*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

tmp/
temp/
.cache/
.cache-loader/

frontend/src.zip


# =========================================================
# OS junk
# =========================================================

.DS_Store
.AppleDouble
.LSOverride
__MACOSX/

Thumbs.db
ehthumbs.db
Desktop.ini


# =========================================================
# IDE / editor
# =========================================================

.vscode/
.idea/

*.swp
*.swo
*.swn
*~

.project
.classpath
.settings/


# =========================================================
# Test / security scan output
# =========================================================

detect-secrets-report.json
bandit-report.json
semgrep-report.json
safety-report.json
pip-audit-report.json

*.sarif


# =========================================================
# Docker / local database artifacts
# =========================================================

*.pid
*.seed
*.sqlite
*.sqlite3

postgres-data/
pgdata/
redis-data/


# =========================================================
# Keep important project files
# =========================================================

!README.md
!ARCHITECTURE.md
!backend/requirements.txt
!frontend/package.json
!frontend/package-lock.json
!frontend/vite.config.js
!frontend/tailwind.config.js
!frontend/postcss.config.js.env.production
