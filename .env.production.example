# -----------------------------------------------------------------------------
# TideMate production environment example
# -----------------------------------------------------------------------------
# Copy this file to .env.production on the server and replace every placeholder.
# Do not commit real secrets.
#
# Important format rules:
# - ALLOWED_HOSTS uses hostnames only. Do not include https:// there.
# - CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS, and WEBSOCKET_ALLOWED_ORIGINS
#   use full origins with https://.
# - For the Docker production stack, DATABASE_URL and REDIS_URL are injected by
#   compose.prod.yml. Set them manually only for non-Compose deployments.
# -----------------------------------------------------------------------------

# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
SECRET_KEY=replace-with-a-long-random-django-secret-key
LOCATION_PRIVACY_SALT=replace-with-a-long-random-location-privacy-salt-at-least-32-chars
DJANGO_ADMIN_URL=replace-with-a-random-admin-path/

# Public hosts and browser origins
# ALLOWED_HOSTS must be hostnames only, not URLs.
# Include 127.0.0.1 because the Docker backend healthcheck uses that host.
ALLOWED_HOSTS=your-domain.example,www.your-domain.example,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
CSRF_TRUSTED_ORIGINS=https://your-domain.example,https://www.your-domain.example
WEBSOCKET_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
FRONTEND_URL=https://your-domain.example

# Production HTTP binding for the Docker frontend container.
# Keep this on loopback and put HTTPS Nginx/Caddy/Cloudflare Tunnel/etc. in front.
FRONTEND_HTTP_BIND=127.0.0.1
FRONTEND_HTTP_PORT=8080

# Database container settings used by compose.prod.yml
POSTGRES_DB=tidemate
POSTGRES_USER=tidemate
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Runtime URLs
# Docker Compose injects these automatically for backend and maintenance:
# DATABASE_URL=postgres://...
# REDIS_URL=redis://...
# For non-Compose deployments, set both as platform secrets.

# Reverse proxy / client IP handling
# Use 1 when Django is behind one trusted reverse proxy. Increase only if your
# actual production path has more trusted proxies that preserve X-Forwarded-For.
NUM_PROXIES=1
AUDIT_TRUSTED_PROXY_COUNT=1

# Auth cookies
JWT_ACCESS_COOKIE_SECURE=True
JWT_REFRESH_COOKIE_SECURE=True
JWT_ACCESS_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_ACCESS_COOKIE_PATH=/
JWT_REFRESH_COOKIE_PATH=/api/users/
JWT_ISSUER=tidemate-api
JWT_AUDIENCE=tidemate-client

# Email / account verification / password reset
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=replace-with-smtp-username
EMAIL_HOST_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=noreply@your-domain.example
EMAIL_VERIFICATION_MAX_AGE_SECONDS=86400

# Google login
# Use the same Google Web Client ID on backend and frontend.
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
VITE_GOOGLE_OAUTH_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com

# Cloudflare Turnstile
# Set both values in production if Turnstile is enabled in the frontend.
TURNSTILE_SECRET_KEY=replace-with-cloudflare-turnstile-secret-key
VITE_TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key

# Stripe payments
STRIPE_SECRET_KEY=sk_live_replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-secret
STRIPE_CURRENCY=nok
STRIPE_PAYMENT_DEADLINE_MINUTES=60
STRIPE_EVENT_RETENTION_DAYS=14
# Stripe webhook endpoint to configure in Stripe Dashboard:
# https://your-domain.example/api/payments/stripe/webhook/

# Scheduled maintenance container
# Pending booking requests are expired every 5 minutes.
MAINTENANCE_BOOKING_EXPIRY_INTERVAL_SECONDS=300

# Old audit events are pruned once per day.
MAINTENANCE_AUDIT_PRUNE_INTERVAL_SECONDS=86400
MAINTENANCE_AUDIT_PRUNE_STARTUP_DELAY_SECONDS=60
AUDIT_EVENT_RETENTION_DAYS=180
MAINTENANCE_AUDIT_PRUNE_BATCH_SIZE=1000

# Old stored Stripe webhook events are pruned once per day.
MAINTENANCE_STRIPE_PRUNE_INTERVAL_SECONDS=86400
MAINTENANCE_STRIPE_PRUNE_STARTUP_DELAY_SECONDS=120

# Upload limits
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_NUMBER_FILES=12
DATA_UPLOAD_MAX_NUMBER_FIELDS=200

# Listing search / location privacy
LISTING_SEARCH_MAX_LIMIT=48
LISTING_SEARCH_MAX_RADIUS_KM=500
LISTING_SEARCH_FALLBACK_MIN_CANDIDATES=48
LISTING_SEARCH_FALLBACK_MAX_CANDIDATES=250
LISTING_SEARCH_PUBLIC_RADIUS_MIN_CANDIDATES=48
LISTING_SEARCH_PUBLIC_RADIUS_MAX_CANDIDATES=250

# Geocoding provider
GEOCODING_PROVIDER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_ALLOWED_HOSTS=nominatim.openstreetmap.org
GEOCODING_REQUIRE_HTTPS=True
GEOCODING_PROVIDER_USER_AGENT="Tidemate/1.0 (contact: your-email@example.com)"
GEOCODING_COUNTRY_CODES=no
GEOCODING_SEARCH_LIMIT=5
GEOCODING_QUERY_MAX_LENGTH=120
GEOCODING_TIMEOUT_SECONDS=4
GEOCODING_SEARCH_CACHE_SECONDS=86400
GEOCODING_REVERSE_CACHE_SECONDS=604800
GEOCODING_RATE=60/hour

# Marine/weather conditions endpoint
MARINE_CONDITIONS_CACHE_TTL_SECONDS=1800
MARINE_CONDITIONS_REQUEST_TIMEOUT_SECONDS=6
MET_NORWAY_USER_AGENT="Tidemate/1.0 (contact: your-email@example.com)"
BOAT_CONDITIONS_ANON_RATE=30/hour
BOAT_CONDITIONS_USER_RATE=120/hour
BOAT_CONDITIONS_GLOBAL_RATE=300/hour

# API throttling
GLOBAL_ANON_RATE=1000/hour
GLOBAL_USER_RATE=5000/hour
REPORT_RATE=10/hour
MODERATION_RATE=120/hour

# Content Security Policy for Django-served responses
# The frontend Docker Nginx has its own CSP for the React app.
CSP_ENABLED=True
CSP_REPORT_ONLY=False
CSP_SCRIPT_SRC_EXTRA=
CSP_STYLE_SRC_EXTRA=
CSP_CONNECT_SRC_EXTRA=
CSP_IMG_SRC_EXTRA=
CSP_FRAME_SRC_EXTRA=

# Monitoring / audit logging
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=INFO
REQUEST_MONITORING_LOG_ENABLED=True
AUDIT_LOGGING_ENABLED=True
AUDIT_AUTOMATIC_API_EVENTS_ENABLED=True
AUDIT_SKIP_PATH_PREFIXES=/api/users/health/,/api/users/csrf/

# Optional debugging helpers
DEBUG_LINKS_ENABLED=False
