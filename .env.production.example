# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
LOCATION_PRIVACY_SALT=replace-with-a-long-random-location-privacy-salt

# Hosts/domains
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
WEBSOCKET_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Production HTTP binding for the Docker frontend container.
# Keep this on loopback and put a real HTTPS reverse proxy in front of it.
FRONTEND_HTTP_BIND=127.0.0.1
FRONTEND_HTTP_PORT=8080

# Database
POSTGRES_DB=tidemate
POSTGRES_USER=tidemate
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Runtime URLs used by backend
# Docker Compose injects DATABASE_URL and REDIS_URL from compose.prod.yml.
# For non-Compose deployments, set DATABASE_URL and REDIS_URL as platform secrets.

# Scheduled maintenance
# Pending booking requests are expired every 5 minutes.
MAINTENANCE_BOOKING_EXPIRY_INTERVAL_SECONDS=300

# Old audit events are pruned once per day.
MAINTENANCE_AUDIT_PRUNE_INTERVAL_SECONDS=86400

# Wait one minute after startup before the first audit prune.
MAINTENANCE_AUDIT_PRUNE_STARTUP_DELAY_SECONDS=60

# Keep security/audit events for 180 days.
# The prune command refuses values below 30 days.
AUDIT_EVENT_RETENTION_DAYS=180

# Number of audit rows deleted per batch.
MAINTENANCE_AUDIT_PRUNE_BATCH_SIZE=1000

# Auth cookies
JWT_ACCESS_COOKIE_SECURE=True
JWT_REFRESH_COOKIE_SECURE=True

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# Frontend/backend public URLs
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com

# Google login
GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com